# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL connection string used by Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/job_tracker?schema=public"

# Auth secrets — use long, random strings in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
ACCESS_TOKEN_SECRET="replace-with-a-long-random-secret"
REFRESH_TOKEN_SECRET="replace-with-a-long-random-secret"
